<!-- pages/home/home.wxml -->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-area">
    <text class="loading-text">登录中...</text>
  </view>

  <block wx:else>
  <!-- 用户信息 -->
  <view class="user-card card">
    <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname}}</text>
      <view class="points-row">
        <text class="points-label">积分</text>
        <text class="points-value points-text">{{pointsDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-grid">
    <view class="menu-item" bindtap="onCreateRoom">
      <text class="menu-icon">🏠</text>
      <text class="menu-label">创建房间</text>
      <text class="menu-desc">邀请好友联机</text>
    </view>
    <view class="menu-item" bindtap="onJoinRoom">
      <text class="menu-icon">🚪</text>
      <text class="menu-label">加入房间</text>
      <text class="menu-desc">输入房间号</text>
    </view>
    <view class="menu-item" bindtap="onAIPractice">
      <text class="menu-icon">🤖</text>
      <text class="menu-label">AI 练习</text>
      <text class="menu-desc">对战机器人</text>
    </view>
    <view class="menu-item" bindtap="onProfile">
      <text class="menu-icon">👤</text>
      <text class="menu-label">个人中心</text>
      <text class="menu-desc">战绩/记录</text>
    </view>
  </view>
  </block>
  <view class="safe-bottom"></view>
</view>
