/* pages/home/home.wxss */
.container {
  padding: 32rpx 64rpx 100rpx;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.loading-area {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.5);
}

.user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 32rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  margin-right: 28rpx;
  border: 3rpx solid rgba(255,215,0,0.5);
  flex-shrink: 0;
}

.user-info { flex: 1; }

.nickname {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.points-row { display: flex; align-items: center; }

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  margin-right: 12rpx;
}

.points-value {
  font-size: 34rpx;
  font-weight: bold;
}

/* 内容区：撑满剩余空间 */
.content-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* 菜单格子：撑满剩余空间 */
.menu-grid {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 36rpx;
}

.menu-item {
  background: rgba(255,255,255,0.08);
  border-radius: 28rpx;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.menu-item:active {
  background: rgba(255,255,255,0.15);
}

.menu-icon {
  font-size: 88rpx;
  margin-bottom: 20rpx;
}

.menu-label {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.menu-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}
