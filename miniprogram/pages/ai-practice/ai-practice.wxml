<!-- pages/ai-practice/ai-practice.wxml -->
<wxs module="fmt">
  function lastChar(s) { return s ? s[s.length - 1] : '?'; }
  module.exports = { lastChar: lastChar };
</wxs>

<!-- 配置界面 -->
<scroll-view wx:if="{{!started}}" class="config-area" scroll-y>
  <text class="config-title">AI 练习</text>
  <view class="config-card card">
    <view class="config-row">
      <text class="config-label">AI 难度</text>
      <picker mode="selector" range="{{difficultyOptions}}" value="{{difficultyIndex}}" bindchange="onDifficultyChange">
        <view class="picker-val">{{difficultyOptions[difficultyIndex]}} ▾</view>
      </picker>
    </view>
    <view class="divider" />
    <view class="config-row">
      <text class="config-label">AI 数量</text>
      <picker mode="selector" range="{{aiCountOptions}}" value="{{aiCount - 1}}" bindchange="onAiCountChange">
        <view class="picker-val">{{aiCountOptions[aiCount - 1]}} ▾</view>
      </picker>
    </view>
  </view>
  <text class="tip">练习模式不影响账号积分</text>
  <button class="btn-primary start-btn" bindtap="onStart" loading="{{loading}}">开始练习</button>

  <!-- 排行榜 -->
  <view class="ranking-section">
    <view class="ranking-header">
      <text class="ranking-title">🏆 AI 对战排行榜</text>
      <text class="ranking-sub">累计赢得筹码</text>
    </view>
    <view wx:if="{{rankingLoading}}" class="ranking-loading">加载中...</view>
    <view wx:elif="{{rankingList.length === 0}}" class="ranking-empty">暂无数据，快去对战吧</view>
    <view wx:else class="ranking-list">
      <view wx:for="{{rankingList}}" wx:key="rank"
        class="ranking-item {{item.isMe ? 'ranking-me' : ''}}">
        <text class="rank-no {{item.rank <= 3 ? 'rank-top' : ''}}">
          {{item.rank === 1 ? '🥇' : item.rank === 2 ? '🥈' : item.rank === 3 ? '🥉' : item.rank}}
        </text>
        <image wx:if="{{item.avatar}}" class="rank-avatar" src="{{item.avatar}}" mode="aspectFill" />
        <view wx:else class="rank-avatar rank-avatar-placeholder">{{fmt.lastChar(item.nickname)}}</view>
        <view class="rank-info">
          <text class="rank-name">{{item.nickname}}{{item.isMe ? ' (我)' : ''}}</text>
          <text class="rank-detail">{{item.totalGames}}局 · 胜率{{item.winRate}}%</text>
        </view>
        <text class="rank-chips {{item.totalChipsWon >= 0 ? 'positive' : 'negative'}}">
          {{item.totalChipsWon >= 0 ? '+' : ''}}{{item.totalChipsWon}}
        </text>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 游戏界面 -->
<view wx:if="{{started}}" class="game-root">

    <!-- 本手结算浮层 -->
    <view wx:if="{{phase === 'ended'}}" class="hand-result-overlay">
      <view class="hand-result-card">
        <text class="hand-result-title">本手结果</text>
        <view wx:for="{{winners}}" wx:key="id" class="hand-result-item">
          <text class="hr-name">{{item.id === 'player' ? '🏆 你赢了' : '🤖 AI 赢了'}}</text>
          <text class="hr-chips">+{{item.potShare}} 筹码</text>
          <text wx:if="{{item.handRank}}" class="hr-rank">{{item.handRank}}</text>
        </view>
        <text class="hr-after">你的筹码: {{myChips}}</text>
        <view class="hr-actions">
          <button class="btn-primary hr-btn" bindtap="onNewRound" loading="{{loading}}">再来一手</button>
          <button class="btn-secondary hr-btn" bindtap="onExit">退出</button>
        </view>
      </view>
    </view>

    <!-- 顶部栏 -->
    <view class="top-bar">
      <view class="top-left">
        <view class="room-tag">
          <text class="room-tag-label">AI 练习</text>
          <text class="room-tag-code">{{difficultyOptions[difficultyIndex]}}</text>
        </view>
        <view class="top-icon-btns">
          <view class="icon-btn exit-btn" bindtap="onExit">
            <image class="icon-img" src="/images/ui/关机.png" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>

    <!-- 牌桌椭圆 -->
    <view class="table-wrapper">
      <view class="table-oval">

        <!-- 底池 + 公共牌 居中 -->
        <view class="board-center">
          <view class="pot-row">
            <text class="pot-label">底池</text>
            <text class="pot-value">{{pot}}</text>
            <view wx:if="{{currentBet > 0}}" class="call-badge">
              <text class="call-badge-text">跟注 {{currentBet}}</text>
            </view>
          </view>
          <view class="community-cards">
            <view wx:for="{{communityCards}}" wx:key="index"
              class="board-card {{index >= prevCardCount ? 'card-reveal' : ''}}"
              style="color:{{item.color}}; animation-delay:{{(index - prevCardCount) * 150}}ms">
              <text class="bc-rank">{{item.rank}}</text>
              <text class="bc-suit">{{item.symbol}}</text>
            </view>
            <view wx:for="{{5 - communityCards.length}}" wx:key="index" class="board-card empty" />
          </view>
          <text wx:if="{{phase && phase !== 'ended'}}" class="phase-label">{{phase}}</text>
          <view wx:if="{{myBestHand}}" class="best-hand-badge">
            <text class="best-hand-text">{{myBestHand}}</text>
          </view>
        </view>

        <!-- AI 玩家节点（绝对定位） -->
        <block wx:for="{{playerStates}}" wx:key="id" wx:if="{{item.isAI}}">
          <view class="player-node seat-pos-{{index}} {{item.status === 'folded' ? 'folded' : ''}}">
            <view class="player-card-wrap">
              <view class="player-avatar-box">
                <view class="p-avatar p-avatar-placeholder">🤖</view>
              </view>
              <view class="player-info-box">
                <text class="p-name">AI {{index}}</text>
                <text class="p-chips">{{item.chips}}</text>
              </view>
            </view>
            <!-- 背面手牌 -->
            <view wx:if="{{item.status !== 'folded' && phase !== 'ended'}}" class="opp-hole-cards">
              <view class="hole-back" /><view class="hole-back" />
            </view>
            <!-- 摊牌 -->
            <view wx:elif="{{item.status !== 'folded' && phase === 'ended'}}" class="opp-hole-cards">
              <view wx:for="{{item.holeCards}}" wx:key="index" wx:for-item="card" class="mini-card-face">
                <text>{{card}}</text>
              </view>
            </view>
            <view wx:if="{{item.betInPhase > 0}}" class="bet-bubble">{{item.betInPhase}}</view>
            <text wx:if="{{item.status === 'folded'}}" class="folded-tag">弃牌</text>
          </view>
        </block>

        <!-- 我的手牌（椭圆底部，绝对定位） -->
        <view class="my-hole-cards-node">
          <view class="my-hole-cards">
            <view wx:for="{{myCards}}" wx:key="index" class="my-card" style="color:{{item.color}}">
              <text class="mc-rank">{{item.rank}}</text>
              <text class="mc-suit">{{item.symbol}}</text>
            </view>
            <view wx:if="{{myCards.length === 0}}" class="my-card empty-card" />
            <view wx:if="{{myCards.length === 0}}" class="my-card empty-card" />
          </view>
        </view>

      </view>
    </view>

    <!-- 我的区域 -->
    <view class="my-zone" style="padding-bottom:calc(16rpx + {{safeAreaBottom}}px)">

      <!-- 筹码 + 回合信息 -->
      <view class="my-info-bar">
        <view class="my-chips-block">
          <text class="my-chips-val">{{myChips}}</text>
        </view>
        <text wx:if="{{isMyTurn}}" class="my-turn-badge">你的回合</text>
        <text wx:elif="{{phase !== 'ended'}}" class="waiting-tip">等待中...</text>
      </view>

      <!-- 操作面板 -->
      <view class="action-zone {{!isMyTurn ? 'action-zone-disabled' : ''}}">

        <!-- 加注展开面板 -->
        <view wx:if="{{showRaiseInput}}" class="raise-panel">
          <view class="raise-amount-row">
            <text class="raise-amount-label">{{isAllinMode ? 'All In' : '加注'}}</text>
            <view class="raise-stepper">
              <view class="stepper-btn" bindtap="onRaiseStep" data-dir="-1">－</view>
              <input class="raise-amount-input" type="number" value="{{raiseAmount}}" bindinput="onRaiseInput" />
              <view class="stepper-btn" bindtap="onRaiseStep" data-dir="1">＋</view>
            </view>
            <button class="raise-confirm-btn {{isAllinMode ? 'allin-confirm' : ''}}" bindtap="onRaise">
              {{isAllinMode ? 'Allin' : '确认'}}
            </button>
          </view>
          <view class="slider-wrap">
            <text class="slider-edge-label">{{sliderMin}}</text>
            <slider
              class="raise-slider"
              min="{{sliderMin}}" max="{{sliderMax}}" value="{{raiseAmount}}"
              step="{{smallBlind || 1}}"
              activeColor="#e67e22" backgroundColor="rgba(255,255,255,0.15)"
              block-color="#ffd700" block-size="24"
              bindchange="onSliderChange" bindchanging="onSliderChange"
            />
            <text class="slider-edge-label right">{{sliderMax}}</text>
          </view>
          <view class="chip-shortcuts">
            <view class="chip chip-w" bindtap="onQuickRaise" data-amount="{{sliderMin}}">MIN</view>
            <view class="chip chip-b" bindtap="onQuickRaise" data-amount="{{pot}}">POT</view>
            <view class="chip chip-p" bindtap="onQuickRaise" data-amount="{{pot * 0.75 | 0}}">3/4</view>
            <view class="chip chip-r" bindtap="onQuickRaise" data-amount="{{pot * 0.5 | 0}}">1/2</view>
            <view class="chip chip-k" bindtap="onQuickRaise" data-amount="{{sliderMax}}">MAX</view>
          </view>
        </view>

        <!-- 主按钮行 -->
        <view class="main-btns">
          <button class="act-btn fold-btn" bindtap="onFold" disabled="{{acting || !isMyTurn}}">弃牌</button>
          <button class="act-btn {{callIsAllin ? 'allin-call-btn' : 'call-btn'}}" bindtap="onCheckCall" disabled="{{acting || !isMyTurn}}">
            <block wx:if="{{callAmount <= 0}}">过牌</block>
            <block wx:elif="{{callIsAllin}}">All In</block>
            <block wx:else>跟注 {{callAmount}}</block>
          </button>
          <button
            class="act-btn {{!canRaise ? 'raise-disabled' : (showRaiseInput ? (isAllinMode ? 'allin-confirm-btn' : 'raise-confirm-active') : 'raise-btn')}}"
            bindtap="onToggleRaise"
            disabled="{{acting || !canRaise || !isMyTurn}}">
            {{showRaiseInput ? (isAllinMode ? '✓ All In' : '✓ 确认加注 ' + raiseAmount) : '加注' + (raiseAmount > 0 ? ' ' + raiseAmount : '')}}
          </button>
        </view>

      </view>
    </view>

</view>

