/* pages/login/login.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffd700;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.logo-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

.login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 80rpx;
}

.login-btn {
  width: 100%;
  margin-bottom: 32rpx;
  font-size: 36rpx;
  padding: 32rpx 0;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

/* 步骤2：设置头像昵称 */
.profile-area {
  display: flex; flex-direction: column; align-items: center;
  width: 100%; padding: 0 80rpx;
}
.profile-title {
  font-size: 36rpx; font-weight: bold; color: #fff;
  margin-bottom: 48rpx;
}
.avatar-btn {
  width: 200rpx !important;
  height: 200rpx !important;
  min-height: 0 !important;
  line-height: 1 !important;
  border-radius: 50% !important;
  padding: 0 !important;
  margin-bottom: 48rpx;
  background: rgba(255,255,255,0.08);
  border: 4rpx solid rgba(255,215,0,0.5) !important;
  overflow: hidden;
  position: relative;
  box-shadow: 0 0 0 6rpx rgba(255,215,0,0.1);
  display: flex !important;
  align-items: center;
  justify-content: center;
}
.avatar-btn::after { border: none !important; }

.avatar-preview {
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  display: block;
}
.avatar-placeholder {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 8rpx;
}
.avatar-placeholder-text {
  font-size: 24rpx; color: rgba(255,255,255,0.5); text-align: center;
  line-height: 1.4;
}

.nickname-wrap {
  width: 100%; margin-bottom: 48rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx; border: 1rpx solid rgba(255,255,255,0.2);
}
.nickname-input {
  width: 100%; height: 88rpx; line-height: 88rpx;
  padding: 0 28rpx; font-size: 32rpx; color: #fff;
  box-sizing: border-box; text-align: center;
}
.nickname-placeholder { color: rgba(255,255,255,0.3); }

.confirm-btn { width: 100%; padding: 32rpx 0; font-size: 36rpx; margin-bottom: 24rpx; }
.skip-text { font-size: 26rpx; color: rgba(255,255,255,0.4); padding: 16rpx; }
