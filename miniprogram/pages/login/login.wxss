/* pages/login/login.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffd700;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.logo-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

.login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 80rpx;
}

.login-btn {
  width: 100%;
  margin-bottom: 32rpx;
  font-size: 36rpx;
  padding: 32rpx 0;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}
