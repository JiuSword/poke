/* pages/room/join/join.wxss */
.container { padding: 80rpx 32rpx; display: flex; flex-direction: column; align-items: center; }
.join-card { width: 100%; text-align: center; margin-bottom: 48rpx; }
.title { font-size: 36rpx; color: rgba(255,255,255,0.8); display: block; margin-bottom: 32rpx; }
.room-input {
  font-size: 64rpx; font-weight: bold; color: #ffd700;
  text-align: center; letter-spacing: 16rpx;
  border-bottom: 3rpx solid rgba(255,215,0,0.4);
  padding: 24rpx 0; min-height: 120rpx; line-height: 1.4;
  width: 100%; box-sizing: border-box;
}
.placeholder { color: rgba(255,255,255,0.2); font-size: 36rpx; letter-spacing: 4rpx; }
.join-btn { width: 100%; padding: 32rpx 0; font-size: 36rpx; }
