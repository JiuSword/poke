/* pages/settlement/settlement.wxss */
.container { padding: 40rpx 32rpx; }
.title { font-size: 48rpx; font-weight: bold; color: #ffd700; text-align: center; display: block; margin-bottom: 40rpx; }
.loading { text-align: center; color: rgba(255,255,255,0.5); padding: 80rpx; }

.settlement-list { margin-bottom: 40rpx; display: flex; flex-direction: column; gap: 20rpx; }

.settlement-item { padding: 28rpx; }
.settlement-item.winner { border-color: rgba(255,215,0,0.5); background: rgba(255,215,0,0.08); }
.settlement-item.me { border-color: rgba(33,150,243,0.5); }

.player-info { display: flex; align-items: center; margin-bottom: 16rpx; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 20rpx; }
.avatar-placeholder {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #fff; margin-right: 20rpx;
}
.name-area { flex: 1; }
.player-name { font-size: 30rpx; color: #fff; display: block; }
.hand-rank { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.winner-badge { font-size: 40rpx; }

.delta-area { display: flex; flex-direction: column; gap: 8rpx; }
.chips-delta, .points-delta { font-size: 28rpx; font-weight: bold; }
.positive { color: #4caf50; }
.negative { color: #f44336; }
.points-after { font-size: 24rpx; color: rgba(255,255,255,0.5); }

.chips-delta { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 4rpx; }
.points-delta { font-size: 36rpx; font-weight: bold; }
.zero-sum-check { text-align: center; padding: 16rpx; }
.zero-sum-text { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.home-btn { width: 100%; padding: 28rpx 0; font-size: 32rpx; margin-top: 16rpx; }
