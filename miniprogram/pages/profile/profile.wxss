/* pages/profile/profile.wxss */
.container { height: 100vh; padding: 32rpx; box-sizing: border-box; }

.user-section { display: flex; align-items: center; margin-bottom: 24rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; margin-right: 24rpx; border: 3rpx solid rgba(255,215,0,0.4); }
.user-info { flex: 1; }
.nickname-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.nickname { font-size: 36rpx; font-weight: bold; color: #fff; }
.edit-btn { font-size: 28rpx; }
.points { font-size: 28rpx; }

.stats-section { margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: rgba(255,255,255,0.8); display: block; margin-bottom: 24rpx; }
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.stat-item { text-align: center; }
.stat-value { font-size: 36rpx; font-weight: bold; color: #ffd700; display: block; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.5); }

.records-section { }

.record-item { margin-bottom: 16rpx; padding: 24rpx; }
.record-header { display: flex; justify-content: space-between; align-items: flex-start; }
.record-left { }
.record-time { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 4rpx; }
.record-room { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.record-right { text-align: right; }
.record-delta { font-size: 36rpx; font-weight: bold; display: block; }
.record-after { font-size: 22rpx; color: rgba(255,255,255,0.4); }

.record-detail { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.detail-row { display: flex; justify-content: space-between; font-size: 24rpx; color: rgba(255,255,255,0.6); margin-bottom: 8rpx; }
.opponent-row { font-size: 22rpx; color: rgba(255,255,255,0.4); padding: 4rpx 0; }

.loading-text, .no-more, .empty-text { text-align: center; color: rgba(255,255,255,0.3); font-size: 26rpx; padding: 40rpx; }

/* 昵称编辑弹窗 — 底部弹出，随键盘上移 */
.edit-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
}
.edit-modal {
  background: #1a1f2e;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx 60rpx;
  width: 100%;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}
.edit-title {
  font-size: 34rpx; font-weight: bold; color: #fff;
  display: block; text-align: center; margin-bottom: 36rpx;
}
.edit-input {
  width: 100%; background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.2); border-radius: 16rpx;
  /* 明确设置高度，防止被截断 */
  height: 88rpx; line-height: 88rpx;
  padding: 0 28rpx; font-size: 32rpx; color: #fff;
  box-sizing: border-box;
}
.edit-placeholder { color: rgba(255,255,255,0.3); }
.edit-count {
  font-size: 22rpx; color: rgba(255,255,255,0.3);
  display: block; text-align: right; margin-top: 8rpx; margin-bottom: 36rpx;
}
.edit-actions { display: flex; gap: 20rpx; }
.edit-cancel {
  flex: 1; padding: 24rpx 0; font-size: 30rpx;
  background: rgba(255,255,255,0.1); color: #fff;
  border: 1rpx solid rgba(255,255,255,0.2); border-radius: 50rpx;
}
.edit-confirm { flex: 1; padding: 24rpx 0; font-size: 30rpx; border-radius: 50rpx; }
